# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# EnrichLayer — LinkedIn profile lookup (reemplaza ProxyCurl)
ENRICHLAYER_API_KEY=your-enrichlayer-api-key

# Pipedrive
PIPEDRIVE_API_TOKEN=your-pipedrive-api-token
PIPEDRIVE_JOB_TITLE_FIELD=your-job-title-custom-field-key
PIPEDRIVE_LINKEDIN_FIELD=your-linkedin-custom-field-key
PIPEDRIVE_LOCATION_FIELD=your-location-custom-field-key
PIPEDRIVE_REVISAR_PERSON_LABEL=your-revisar-person-label-id
PIPEDRIVE_REVISAR_ORG_LABEL=your-revisar-org-label-id
PIPEDRIVE_PREVIOUS_COMPANY_FIELD=your-previous-company-field-key
PIPEDRIVE_PREVIOUS_PROFILE_FIELD=your-previous-profile-field-key

# URL pública de la app — debe apuntar a producción en Vercel
# También añadir en Supabase → Authentication → URL Configuration → Redirect URLs
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Dominio de Pipedrive (ej. "manfred" para manfred.pipedrive.com)
NEXT_PUBLIC_PIPEDRIVE_DOMAIN=app
